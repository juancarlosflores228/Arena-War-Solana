{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "target/ts-tests",
    "types": ["mocha", "node"]
  },
  "include": ["tests/**/*.ts", "target/types/**/*.ts"]
}
